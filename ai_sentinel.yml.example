  #         system: "You are a concise technical writer. Summarize website content in 3-5 sentences."
  #         prompt: "Summarize the following website content:\n\n{{fetch.body}}"
  #         remember: false
  #
  #     - id: save
  #       action: shell_command
  #       params:
  #         command: 'echo "{{summarize.response}}" > "site_summary_$(date +%Y%m%d_%H%M%S).txt"'

