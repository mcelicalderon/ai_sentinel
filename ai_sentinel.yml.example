# ai_sentinel.yml
#
# Configuration file for AiSentinel.
# Copy this file to ai_sentinel.yml and customize it.
#
# API keys should be set via environment variables (e.g. in .env):
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENAI_API_KEY=sk-...

global:
  provider: anthropic         # anthropic or openai
  model: claude-sonnet-4-20250514    # default model for your provider
  # database: ./ai_sentinel.sqlite3
  # max_context_messages: 50
  # on_prompt_change: ask               # ask, keep, or drop
  # log_file: ./logs/ai_sentinel.log    # omit to log to STDOUT
  # log_file_size: 10485760             # 10 MB per file (default)
  # log_files: 5                        # rotated files to keep (default)
  # base_url: https://api.openai.com/v1/chat/completions  # for OpenAI-compatible APIs (Ollama, LM Studio, etc.)

workflows:
  # Summarize a website every minute
  summarize_site:
    schedule: "* * * * *"
    steps:
      - id: fetch
        action: http_get
        params:
          url: "https://example.com"

      - id: summarize
        action: ai_prompt
        params:
          system: "You are a concise technical writer. Summarize website content in 3-5 sentences."
          prompt: "Summarize the following website content:\n\n{{fetch.body}}"
          remember: false

      - id: save
        action: shell_command
        params:
          command: 'echo "{{summarize.response}}" > "site_summary_$(date +%Y%m%d_%H%M%S).txt"'

  # Monitor an API and alert on anomalies (every 6 hours)
  # price_monitor:
