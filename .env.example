# AiSentinel Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# API key for your chosen provider (set the one you use)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Database path (defaults to ~/.ai_sentinel/db.sqlite3)
# AI_SENTINEL_DATABASE_PATH=/path/to/db.sqlite3
